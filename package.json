{
  "name": "appsc",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"next dev\" \"npm run agent\"",
    "agent": "python lib/agent.py dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "seed:departments": "npx tsx scripts/seed-departments.ts",
    "seed:admin": "npx tsx scripts/seed-admin.ts",
    "seed:dept-admin": "npx tsx scripts/seed-dept-admin.ts",
    "migrate:roles": "npx tsx scripts/migrate-roles.ts",
    "migrate:phe:dry-run": "node scripts/migrate_phe_complaints.js --dry-run",
    "migrate:phe": "node scripts/migrate_phe_complaints.js --execute",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:legacy": "npx tsx scripts/run-tests.ts"
  },
  "dependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/uuid": "^10.0.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.4",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.23",
    "happy-dom": "^20.8.3",
    "jsonwebtoken": "^9.0.3",
    "livekit-server-sdk": "^2.15.0",
    "lucide-react": "^0.575.0",
    "mongoose": "^9.2.3",
    "next": "^16.1.6",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "uuid": "^13.0.0",
    "vitest": "^4.0.18",
    "zod": "^4.3.6"
  }
}
